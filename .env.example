# Cloudinary - Public (dùng để upload ảnh từ browser)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=""

# Cloudinary - Private (dùng để xóa ảnh từ server, KHÔNG được có NEXT_PUBLIC_)
# Lấy từ: Cloudinary Dashboard → Settings → API Keys
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Vercel Postgres Configuration (Lấy từ tab Storage trong project Vercel của bạn)
POSTGRES_PRISMA_URL=""
POSTGRES_URL_NON_POOLING=""

# Auth - Mật mã đăng nhập (tự đặt tùy ý)
PRINCE_PASSCODE=""
PRINCESS_PASSCODE=""

# Session Secret - Chuỗi bí mật để ký cookie (dài tối thiểu 32 ký tự)
# Tạo bằng: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""
